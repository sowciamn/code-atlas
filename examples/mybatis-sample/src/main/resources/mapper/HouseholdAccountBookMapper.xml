<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.HouseholdAccountBookMapper">
    <select id="findByMonth" resultType="string">
        select
            hab.id,
            hab.account_date,
            c.name as category_name
        from
            household_account_book hab
        left join
            category c
        on
            hab.category_id = c.id
        where
            hab.target_month = #{targetMonth}
    </select>
    <insert id="insert">
        insert into household_account_book (
            item_name
        ) values (
            #{item}
        )
    </insert>
    <update id="update">
        update household_account_book
        set item_name = #{item}
        where id = #{id}
    </update>
    <delete id="deleteById">
        delete from household_account_book
        where id = #{id}
    </delete>
</mapper>
